---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import StepsForm from '../components/StepsForm.astro';
import CityMap from '../components/CityMap.astro';
import communes from '../data/communes.json';
import { generateCommuneContent, getDynamicPrices, getClimateZone } from '../lib/contentEngine';
import { getSmartNearbyCommunes } from '../lib/geoLinks';
import config from '../data/config.json';

export async function getStaticPaths() {
  return communes.map((commune) => ({
    params: { commune: commune.slug },
    props: { commune }
  }));
}

const { commune } = Astro.props;

// Generate spun localized content for copropriete category
const content = generateCommuneContent(commune, 'copropriete');
const prices = getDynamicPrices(commune);
const climateZone = getClimateZone(commune.codePostal, commune.slug);
const nearbyCommunes = getSmartNearbyCommunes(commune.slug, communes, 6, 2);

const title = `Borne de Recharge Copropriété à ${commune.nom} (${commune.codePostal}) — Droit à la Prise`;
const description = `Vous habitez en copropriété à ${commune.nom} ? Installez une borne individuelle ou collective sur votre place de parking. Profitez d'ADVENIR (960€) et de nos artisans IRVE.`;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes (13)", href: "/communes/" },
  { label: commune.nom, href: `/installateur-borne-recharge-${commune.slug}/` },
  { label: "Copropriété" }
];
---

<Layout title={title} description={description}>
  <SchemaMarkup 
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    faqItems={content.faqItems}
    breadcrumbItems={breadcrumbItems}
    communeName={commune.nom}
  />

  <Breadcrumb items={breadcrumbItems} />

  <!-- Localized Hero Section -->
  <section class="city-hero" style="background: linear-gradient(135deg, var(--secondary) 0%, #0f172a 100%); color: white; padding: 60px 0 80px; position: relative; overflow: hidden; border-bottom: 1px solid var(--border-color);">
    <div class="tech-pattern"></div>
    <div class="container" style="position: relative; z-index: 2;">
      <div class="hero-columns" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 40px; align-items: center;">
        
        <!-- Left Text Column -->
        <div class="hero-left">
          <div class="zfe-badge-pill" style="display: inline-flex; align-items: center; background: var(--accent); color: white; padding: 6px 14px; border-radius: 9999px; font-size: 13px; font-weight: 800; font-family: var(--font-body); margin-bottom: 25px; text-transform: uppercase;">
            🏢 Droit à la prise Garanti (Décret 2020)
          </div>
          
          <h1 style="font-family: var(--font-heading); font-size: 38px; font-weight: 800; line-height: 1.25; margin-bottom: 20px; color: white;">
            Borne de Recharge en Copropriété à {commune.nom}
          </h1>
          
          <p style="font-size: 17.5px; line-height: 1.6; color: var(--primary-light); margin-bottom: 25px;">
            {content.introParagraph}
          </p>

          <div class="key-features-list" style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 30px;">
            <div style="display: flex; align-items: center; gap: 10px; font-size: 14.5px;">
              <span style="color: var(--accent); font-size: 18px;">✓</span> Prime ADVENIR 50% (Plafond 960€)
            </div>
            <div style="display: flex; align-items: center; gap: 10px; font-size: 14.5px;">
              <span style="color: var(--accent); font-size: 18px;">✓</span> Crédit d'impôt 500 € individuel
            </div>
            <div style="display: flex; align-items: center; gap: 10px; font-size: 14.5px;">
              <span style="color: var(--accent); font-size: 18px;">✓</span> Raccordement conforme TGBT
            </div>
            <div style="display: flex; align-items: center; gap: 10px; font-size: 14.5px;">
              <span style="color: var(--accent); font-size: 18px;">✓</span> Gestion administrative syndic incluse
            </div>
          </div>

          <div class="local-fact-card" style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15); padding: 20px; border-radius: var(--radius-md); backdrop-filter: blur(10px);">
            <h4 style="margin: 0 0 8px; font-size: 14px; font-family: var(--font-heading); text-transform: uppercase; color: var(--accent);">Focus Logement : {commune.nom}</h4>
            <p style="margin: 0; font-size: 13.5px; color: var(--primary-light); line-height: 1.5;">
              La commune dispose de {commune.logements?.toLocaleString('fr-FR')} logements. La proportion de résidences collectives y est importante, nécessitant un accompagnement précis pour l'équipement en bornes IRVE individuelles avec comptage MID ou infrastructures collectives Linky.
            </p>
          </div>
        </div>

        <!-- Right Form Column -->
        <div class="hero-right">
          <div id="devis-form-container" style="background: var(--card-bg); border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-lg); overflow: hidden;">
            <div style="background: var(--secondary); padding: 20px 30px; text-align: center; border-bottom: 2px solid var(--border-color);">
              <h3 style="margin: 0; color: white; font-family: var(--font-heading); font-size: 18px; font-weight: 700;">Simuler mes aides en Copropriété</h3>
              <p style="margin: 5px 0 0; color: var(--primary-light); font-size: 12.5px;">Artisans IRVE qualifiés intervenant à {commune.nom}</p>
            </div>
            <div style="padding: 25px 30px;">
              <StepsForm initialZip={commune.codePostal} />
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Localized Detail Content Section -->
  <section class="city-details" style="padding: 60px 0 80px; background-color: var(--bg);">
    <div class="container">
      <div class="two-column-layout" style="display: grid; grid-template-columns: 2.5fr 1fr; gap: 40px; align-items: start;">
        
        <!-- Main spun content card -->
        <div class="city-main-content rich-text" style="background: var(--card-bg); padding: 45px; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
          
          <h2 style="font-family: var(--font-heading); font-size: 26px; font-weight: 700; color: var(--primary); margin-top: 0; margin-bottom: 20px;">
            Faire valoir son Droit à la Prise en Résidence à {commune.nom}
          </h2>
          <p>
            {content.localContext}
          </p>
          
          <blockquote>
            {content.logisticsAlert}
          </blockquote>

          <h2 style="font-family: var(--font-heading); font-size: 24px; font-weight: 700; color: var(--primary); margin-top: 35px; margin-bottom: 15px;">
            Tarifs de raccordement en habitat collectif à {commune.nom}
          </h2>
          <p>{content.tableIntro}</p>

          <table class="data-table" style="width: 100%; border-collapse: collapse; margin: 25px 0;">
            <thead>
              <tr style="background-color: var(--primary-light); color: var(--primary);">
                <th style="padding: 12px; border: 1px solid var(--border-color); text-align: left;">Type de solution</th>
                <th style="padding: 12px; border: 1px solid var(--border-color); text-align: left;">Spécificités techniques</th>
                <th style="padding: 12px; border: 1px solid var(--border-color); text-align: right;">Tarif moyen posé TTC (Brut)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td style="padding: 12px; border: 1px solid var(--border-color);"><strong>Pose Wallbox 7.4 kW (Individuelle)</strong></td>
                <td style="padding: 12px; border: 1px solid var(--border-color);">Liaison compteur parties communes + sous-compteur MID</td>
                <td style="padding: 12px; border: 1px solid var(--border-color); text-align: right; font-family: var(--font-mono); font-weight: 700; color: var(--accent);">{prices.wallbox7kW.min} € – {prices.wallbox7kW.max} €</td>
              </tr>
              <tr style="background-color: #fafaf9;">
                <td style="padding: 12px; border: 1px solid var(--border-color);"><strong>Abonnement Enedis Individuel</strong></td>
                <td style="padding: 12px; border: 1px solid var(--border-color);">Nouveau Point de Livraison Enedis + compteur Linky dédié</td>
                <td style="padding: 12px; border: 1px solid var(--border-color); text-align: right; font-family: var(--font-mono); font-weight: 700; color: var(--accent);">{prices.copro.min} € – {prices.copro.max} €</td>
              </tr>
              <tr>
                <td style="padding: 12px; border: 1px solid var(--border-color);"><strong>Infrastructure Collective (Place)</strong></td>
                <td style="padding: 12px; border: 1px solid var(--border-color);">Pré-équipement colonne montante dans le parking (coût/place)</td>
                <td style="padding: 12px; border: 1px solid var(--border-color); text-align: right; font-family: var(--font-mono); font-weight: 700; color: var(--accent);">{prices.copro.min} € – {prices.copro.max} €</td>
              </tr>
            </tbody>
          </table>
          <p style="font-size: 13px; color: var(--text-muted); line-height: 1.45;">{content.pricesContext}</p>

          <h2 style="font-family: var(--font-heading); font-size: 24px; font-weight: 700; color: var(--primary); margin-top: 35px; margin-bottom: 15px;">
            Fonctionnement technique et Gestion des consommations en copropriété à {commune.nom}
          </h2>
          <p>
            {content.useCaseText} {content.ecoText}
          </p>
          <p>
            Grâce à la prime ADVENIR copropriété de 50%, les habitants de {commune.nom} peuvent réduire leur budget d'installation d'une valeur de 960 € TTC, faisant de la recharge en sous-sol une solution très abordable.
          </p>

          <h2 style="font-family: var(--font-heading); font-size: 24px; font-weight: 700; color: var(--primary); margin-top: 35px; margin-bottom: 15px;">
            La réglementation copropriété et le rôle du syndic à {commune.nom}
          </h2>
          <p>
            {content.communeDataInsight} {content.realEstateInsight} {content.populationTierContent}
          </p>

          <div style="background: var(--primary-light); border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 25px; margin-top: 35px; display: flex; gap: 15px; align-items: start;">
            <span style="font-size: 24px; display: block;">🏢</span>
            <div>
              <h4 style="margin: 0 0 6px; font-family: var(--font-heading); color: var(--primary); font-size: 16px; font-weight: 700;">Le conseil d'expert copropriété</h4>
              <p style="margin: 0; font-size: 14px; line-height: 1.5; color: var(--text);">{content.expertTip}</p>
            </div>
          </div>

          <h2 style="font-family: var(--font-heading); font-size: 24px; font-weight: 700; color: var(--primary); margin-top: 40px; margin-bottom: 15px;">
            État du réseau de recharge à {commune.nom}
          </h2>
          <p>
            {content.densiteAnalysis}
          </p>
          <p>
            {content.distanceMarseilleContext}
          </p>

          <h2 style="font-family: var(--font-heading); font-size: 24px; font-weight: 700; color: var(--primary); margin-top: 35px; margin-bottom: 15px;">
            Cadre réglementaire copropriété à {commune.nom}
          </h2>
          <p>
            {content.localRegulation}
          </p>
          <p>
            {content.marcheImmobilierInsight}
          </p>

          <p style="font-size: 12px; color: var(--text-muted); margin-top: 30px; padding-top: 15px; border-top: 1px solid var(--border-color); line-height: 1.5; font-style: italic;">
            {content.sourcesCitation} Dernière mise à jour : {content.lastUpdated}.
          </p>

          <!-- In-content pillar links (SEO) -->
          <h2 style="font-family: var(--font-heading); font-size: 24px; font-weight: 700; color: var(--primary); margin-top: 40px; margin-bottom: 15px;">
            Pour aller plus loin — Copropriété & Aides
          </h2>
          <div style="display: grid; grid-template-columns: 1fr; gap: 12px;">
            {content.pillarLinks.map(p => (
              <a href={p.href} style="display: flex; align-items: center; gap: 12px; padding: 14px 18px; background: var(--primary-light); border-radius: var(--radius-sm); border: 1px solid var(--border-color); text-decoration: none; transition: transform 0.15s ease;">
                <span style="font-size: 14px; font-weight: 700; color: var(--primary); font-family: var(--font-heading);">{p.label}</span>
                <span style="font-size: 12.5px; color: var(--text-muted); margin-left: auto;">{p.desc}</span>
              </a>
            ))}
          </div>

          <!-- Google Maps Iframe -->
          <h2 style="font-family: var(--font-heading); font-size: 24px; font-weight: 700; color: var(--primary); margin-top: 45px; margin-bottom: 15px;">
            Zone d'intervention en résidence collective à {commune.nom}
          </h2>
          <p>
            Nos électriciens partenaires agréés IRVE réalisent le câblage et la pose de bornes individuelles dans tous les parkings privatifs ou collectifs à {commune.nom}.
          </p>
          <CityMap cityName={commune.nom} zip={commune.codePostal} />

          <!-- FAQ Accordion -->
          <h2 style="font-family: var(--font-heading); font-size: 24px; font-weight: 700; color: var(--primary); margin-top: 45px; margin-bottom: 20px;">
            Questions fréquentes — Recharge en copropriété à {commune.nom}
          </h2>
          <div class="faq-accordion" style="display: flex; flex-direction: column; gap: 15px;">
            {content.faqItems.map((faq, idx) => (
              <details style="background: white; border: 1px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px 20px;" open={idx === 0}>
                <summary style="font-family: var(--font-heading); font-weight: 700; color: var(--primary); cursor: pointer; font-size: 15px; display: flex; justify-content: space-between; align-items: center; list-style: none;">
                  <span>{faq.question}</span>
                  <span style="color: var(--accent); font-weight: bold;">▾</span>
                </summary>
                <p style="margin-top: 12px; margin-bottom: 0; font-size: 14.5px; line-height: 1.5; color: var(--text-muted);">
                  {faq.answer}
                </p>
              </details>
            ))}
          </div>

        </div>

        <!-- Sidebar / Navigation widget -->
        <aside class="city-sidebar" style="display: flex; flex-direction: column; gap: 30px;">
          
          <!-- Local Info Widget -->
          <div class="sidebar-widget" style="background: var(--card-bg); padding: 25px; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 700; color: var(--primary); margin-bottom: 15px; border-bottom: 2px solid var(--primary-light); padding-bottom: 8px;">
              📍 Fiche Technique {commune.nom}
            </h3>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; font-size: 13.5px; color: var(--text);">
              <li style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--primary-light); padding-bottom: 8px;">
                <span>Code Postal</span>
                <strong>{commune.codePostal}</strong>
              </li>
              <li style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--primary-light); padding-bottom: 8px;">
                <span>Logements totaux</span>
                <strong>{commune.logements?.toLocaleString('fr-FR')}</strong>
              </li>
              <li style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--primary-light); padding-bottom: 8px;">
                <span>Proportion maisons</span>
                <strong>{commune.logementsMaison} %</strong>
              </li>
              <li style="display: flex; justify-content: space-between; border-bottom: 1px solid var(--primary-light); padding-bottom: 8px;">
                <span>Proportion appartements</span>
                <strong>{100 - commune.logementsMaison} %</strong>
              </li>
            </ul>
          </div>

          <!-- Dynamic links page types (main & wallbox) -->
          <div class="sidebar-widget" style="background: var(--card-bg); padding: 25px; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 700; color: var(--primary); margin-bottom: 15px; border-bottom: 2px solid var(--primary-light); padding-bottom: 8px;">
              📁 Autres Solutions
            </h3>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 12px; font-size: 13.5px;">
              <li>
                👉 <a href={`/installateur-borne-recharge-${commune.slug}/`} style="color: var(--secondary); font-weight: 700; text-decoration: none;">Installateur Principal {commune.nom}</a>
              </li>
              <li>
                👉 <a href={`/wallbox-${commune.slug}/`} style="color: var(--secondary); font-weight: 700; text-decoration: none;">Choisir une Wallbox à {commune.nom}</a>
              </li>
            </ul>
          </div>

          <!-- Internal links recommendations (guides) -->
          <div class="sidebar-widget" style="background: var(--card-bg); padding: 25px; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 700; color: var(--primary); margin-bottom: 15px; border-bottom: 2px solid var(--primary-light); padding-bottom: 8px;">
              📚 Guides Recommandés
            </h3>
            <div style="display: flex; flex-direction: column; gap: 15px;">
              {content.guideLinks.map(g => (
                <div style="font-size: 13px;">
                  <a href={g.href} style="color: var(--secondary); font-weight: 700; text-decoration: none; display: block; margin-bottom: 3px;">{g.label}</a>
                  <span style="color: var(--text-muted); line-height: 1.4; display: block;">{g.desc}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Official Links -->
          <div class="sidebar-widget" style="background: var(--card-bg); padding: 25px; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 700; color: var(--primary); margin-bottom: 15px; border-bottom: 2px solid var(--primary-light); padding-bottom: 8px;">
              🔗 Ressources Officielles
            </h3>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 15px; font-size: 12.5px;">
              {content.externalLinks.map(link => (
                <li>
                  <a href={link.url} target="_blank" rel="noopener noreferrer" style="color: var(--secondary); font-weight: 700; text-decoration: none; display: block; margin-bottom: 3px;">
                    {link.label} &rarr;
                  </a>
                  <span style="color: var(--text-muted); line-height: 1.35; display: block;">{link.description}</span>
                </li>
              ))}
            </ul>
          </div>

          <!-- Localized Proximity Links -->
          <div class="sidebar-widget" style="background: var(--card-bg); padding: 25px; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 700; color: var(--primary); margin-bottom: 15px; border-bottom: 2px solid var(--primary-light); padding-bottom: 8px;">
              📍 Copropriétés Voisines
            </h3>
            <ul style="list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; font-size: 13px;">
              {nearbyCommunes.map((c) => (
                <li>
                  <a href={`/borne-recharge-copropriete-${c.slug}/`} style="color: var(--text); text-decoration: none; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #f3f4f6; padding-bottom: 6px;">
                    <span>{c.nom} <span style="font-size: 11px; color: var(--text-muted);">({c.codePostal})</span></span>
                    <span style="color: var(--accent); font-weight: bold;">&rarr;</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

        </aside>

      </div>
    </div>
  </section>

</Layout>

<style>
  .tech-pattern {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: radial-gradient(rgba(244, 63, 94, 0.05) 1px, transparent 0);
    background-size: 24px 24px;
    z-index: 1;
  }
  
  @media (max-width: 992px) {
    .hero-columns {
      grid-template-columns: 1fr !important;
      gap: 30px !important;
    }
    .two-column-layout {
      grid-template-columns: 1fr !important;
      gap: 35px !important;
    }
  }

  /* Rich text styles */
  .rich-text :global(h2) {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: 700;
    color: var(--primary);
    margin-top: 35px;
    margin-bottom: 15px;
    border-bottom: 1.5px solid var(--border-color);
    padding-bottom: 8px;
  }
  .rich-text :global(p) {
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--text);
    margin-bottom: 20px;
  }
  .rich-text :global(blockquote) {
    border-left: 4px solid var(--accent);
    background: var(--primary-light);
    padding: 15px 25px;
    margin: 25px 0;
    border-radius: var(--radius-sm);
    color: var(--primary);
    font-style: italic;
    font-size: 14.5px;
    line-height: 1.5;
  }
  
  /* Details summary dropdown styles */
  summary::-webkit-details-marker {
    display: none;
  }
  details summary:hover {
    color: var(--secondary) !important;
  }
</style>
