---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
import config from '../../data/config.json';

const title = `Guides, Conseils & Fiscalité Borne de Recharge Bouches-du-Rhône — Blog IRVE`;
const description = `Retrouvez tous nos articles, dossiers techniques et conseils fiscaux (aides, ZFE Marseille, solaire, copropriété) rédigés par nos électriciens IRVE du 13.`;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Guides & Conseils" }
];

// Fetch and sort guides by publishDate descending
const allGuides = await getCollection('guides');
const sortedGuides = allGuides.sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime());
---

<Layout title={title} description={description}>
  <SchemaMarkup 
    slot="head" 
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    breadcrumbItems={breadcrumbItems}
  />

  <Breadcrumb items={breadcrumbItems} />

  <section class="guides-hero" style="background: linear-gradient(135deg, var(--primary) 0%, #0f172a 100%); color: white; padding: 60px 0; text-align: center; position: relative; overflow: hidden;">
    <div class="tech-pattern"></div>
    <div class="container" style="position: relative; z-index: 2;">
      <span class="badge" style="background-color: var(--accent); color: white; font-family: var(--font-body); font-weight: 700; padding: 6px 12px; border-radius: 9999px; font-size: 13px; text-transform: uppercase;">Le Blog IRVE du 13</span>
      <h1 style="font-family: var(--font-heading); font-size: 38px; font-weight: 800; margin-top: 15px; margin-bottom: 15px; color: white;">Guides Pratiques &amp; Réglementations Borne de Recharge</h1>
      <p style="font-size: 18px; max-width: 800px; margin: 0 auto; color: var(--border-color); line-height: 1.6;">
        Toutes les clés pour réussir l'installation de votre borne de recharge électrique dans les Bouches-du-Rhône : aides de l'État, législation en copropriété, délestages Linky et guides techniques.
      </p>
    </div>
  </section>

  <section class="guides-grid-section" style="padding: 60px 0 80px; background-color: var(--bg);">
    <div class="container">
      
      {sortedGuides.length === 0 ? (
        <div style="text-align: center; padding: 40px; background: white; border-radius: var(--radius-md); border: 1px solid var(--border-color);">
          <p>Aucun guide disponible pour le moment. Revenez très bientôt !</p>
        </div>
      ) : (
        <div class="guides-list-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 30px;">
          {sortedGuides.map((guide) => (
            <article class="guide-card" style="background: var(--card-bg); border-radius: var(--radius-md); overflow: hidden; border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); display: flex; flex-direction: column; transition: transform 0.2s ease, box-shadow 0.2s ease;">
              <a href={`/guides/${guide.id}/`} class="guide-card-image-link" style="display: block; position: relative; padding-bottom: 56.25%; background-color: var(--primary-light); overflow: hidden;">
                <img 
                  src={guide.data.image} 
                  alt={guide.data.title}
                  style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;"
                  loading="lazy"
                  class="guide-thumbnail"
                />
                <span class="guide-card-category" style="position: absolute; top: 15px; left: 15px; background: var(--secondary); color: white; padding: 4px 10px; border-radius: var(--radius-sm); font-size: 12px; font-weight: 700; text-transform: uppercase;">
                  {guide.data.category}
                </span>
              </a>
              <div class="guide-card-content" style="padding: 25px; flex-grow: 1; display: flex; flex-direction: column;">
                <div class="guide-meta" style="font-family: var(--font-body); font-size: 12px; color: var(--text-muted); margin-bottom: 12px; display: flex; gap: 15px;">
                  <span>📅 {guide.data.publishDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                  <span>⏱️ {guide.data.readTime}</span>
                </div>
                <h2 style="font-family: var(--font-heading); font-size: 20px; font-weight: 700; color: var(--primary); margin-bottom: 12px; line-height: 1.4;">
                  <a href={`/guides/${guide.id}/`} style="color: inherit; text-decoration: none; transition: color 0.2s;">
                    {guide.data.title}
                  </a>
                </h2>
                <p style="color: var(--text-muted); font-size: 14.5px; line-height: 1.5; margin-bottom: 20px; flex-grow: 1;">
                  {guide.data.description}
                </p>
                <a href={`/guides/${guide.id}/`} class="read-more-link" style="font-weight: 700; color: var(--secondary); text-decoration: none; display: inline-flex; align-items: center; gap: 5px; font-size: 14px; margin-top: auto; align-self: flex-start;">
                  Lire l'article <span style="font-size: 16px;">→</span>
                </a>
              </div>
            </article>
          ))}
        </div>
      )}

      <!-- Call to Action Banner -->
      <div class="blog-cta-banner" style="margin-top: 60px; background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%); color: white; padding: 45px; border-radius: var(--radius-md); box-shadow: var(--shadow-md); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 30px; border: 1.5px solid var(--border-color);">
        <div style="flex: 1; min-width: 280px;">
          <h3 style="font-family: var(--font-heading); font-size: 24px; font-weight: 800; margin-bottom: 10px;">Besoin d'installer une borne de recharge dans les Bouches-du-Rhône ?</h3>
          <p style="font-size: 15.5px; color: var(--primary-light); line-height: 1.5; margin-bottom: 0;">
            Bénéficiez de la prime ADVENIR 2026 et du crédit d'impôt de 500 € en confiant votre installation à un artisan qualifié IRVE. Devis gratuit sous 48 heures.
          </p>
        </div>
        <div style="flex-shrink: 0;">
          <a href="/devis/" class="cta-btn-amber" style="display: inline-block; background-color: var(--accent); color: white; padding: 15px 30px; border-radius: 9999px; font-weight: 800; text-decoration: none; transition: background-color 0.2s, transform 0.1s; text-transform: uppercase; font-size: 14px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
            Comparer les devis gratuits →
          </a>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  .tech-pattern {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: radial-gradient(rgba(244, 63, 94, 0.05) 1px, transparent 0);
    background-size: 24px 24px;
    z-index: 1;
  }
  
  .guide-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md) !important;
  }
  .guide-card:hover .guide-thumbnail {
    transform: scale(1.05);
  }
  .guide-card:hover h2 a {
    color: var(--secondary) !important;
  }
  .read-more-link:hover {
    text-decoration: underline !important;
  }
</style>
