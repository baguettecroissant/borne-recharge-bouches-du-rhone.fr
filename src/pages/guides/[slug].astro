---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
import config from '../../data/config.json';

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const title = `${entry.data.title} | ${config.brandName}`;
const description = entry.data.description;

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Guides & Conseils", href: "/guides/" },
  { label: entry.data.title }
];

// Fetch other guides for the sidebar/footer recommendations
const allGuides = await getCollection('guides');
const recommendations = allGuides
  .filter((g) => g.id !== entry.id)
  .slice(0, 3);
---

<Layout title={title} description={description}>
  <SchemaMarkup 
    slot="head" 
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    breadcrumbItems={breadcrumbItems}
  />

  <Breadcrumb items={breadcrumbItems} />

  <article class="guide-detail-section" style="padding: 50px 0 80px; background-color: var(--bg);">
    <div class="container">
      <div class="two-column-layout" style="display: grid; grid-template-columns: 2.5fr 1fr; gap: 40px; align-items: start;">
        
        <!-- Main Content Area -->
        <div class="guide-main-area" style="display: flex; flex-direction: column; gap: 30px;">
          
          <!-- Article Header Card -->
          <div class="guide-header-card" style="background: var(--card-bg); border-radius: var(--radius-md); border: 1px solid var(--border-color); overflow: hidden; box-shadow: var(--shadow-sm);">
            <div class="guide-cover-wrapper" style="position: relative; padding-bottom: 45%; background-color: var(--primary-light); overflow: hidden;">
              <img 
                src={entry.data.image} 
                alt={entry.data.title} 
                style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover;"
              />
            </div>
            
            <div class="guide-header-details" style="padding: 40px;">
              <span class="guide-badge" style="background: var(--primary-light); color: var(--primary); font-family: var(--font-body); font-weight: 700; padding: 6px 14px; border-radius: 9999px; font-size: 13px; text-transform: uppercase; border: 1px solid var(--border-color); display: inline-block; margin-bottom: 20px;">
                {entry.data.category}
              </span>
              
              <h1 style="font-family: var(--font-heading); font-size: 34px; font-weight: 800; color: var(--primary); margin-bottom: 20px; line-height: 1.3;">
                {entry.data.title}
              </h1>
              
              <div class="guide-meta-bar" style="display: flex; flex-wrap: wrap; gap: 20px; font-family: var(--font-body); font-size: 13.5px; color: var(--text-muted); padding-top: 15px; border-top: 1px solid var(--border-color);">
                <span>👤 Rédacteur : <strong>{entry.data.author}</strong></span>
                <span>📅 Publié le : <strong>{entry.data.publishDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}</strong></span>
                <span>⏱️ Temps de lecture : <strong>{entry.data.readTime}</strong></span>
              </div>
            </div>
          </div>

          <!-- Article Body Card -->
          <div class="guide-body-card rich-text" style="background: var(--card-bg); border-radius: var(--radius-md); border: 1px solid var(--border-color); padding: 50px 40px; box-shadow: var(--shadow-sm);">
            <Content />
          </div>

          <!-- Bottom Banner (Inside Content Stream) -->
          <div style="background: var(--primary-light); border: 1.5px dashed var(--border-color); border-radius: var(--radius-md); padding: 30px; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 15px;">
            <span style="font-size: 28px;">🔌</span>
            <h3 style="font-family: var(--font-heading); font-size: 20px; font-weight: 700; color: var(--primary); margin: 0;">Faites poser votre Borne par un Installateur IRVE Agréé</h3>
            <p style="font-size: 14.5px; color: var(--text); max-width: 600px; margin: 0; line-height: 1.5;">
              Nos partenaires électriciens qualifiés IRVE dans les Bouches-du-Rhône (13) étudient votre projet gratuitement. Recevez 3 devis comparatifs détaillés sous 48h.
            </p>
            <a href="/devis/" class="cta-btn-amber" style="background-color: var(--accent); color: white; padding: 12px 25px; border-radius: 9999px; font-weight: 800; text-decoration: none; font-size: 13px; text-transform: uppercase; margin-top: 5px;">
              Demander mes Devis Gratuits
            </a>
          </div>

        </div>

        <!-- Sidebar -->
        <aside class="guide-sidebar" style="display: flex; flex-direction: column; gap: 30px;">
          
          <!-- CTA Form Widget -->
          <div class="sidebar-widget bg-purple-gradient" style="background: linear-gradient(135deg, var(--primary) 0%, #0f172a 100%); color: white; padding: 30px; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 700; margin-bottom: 15px; color: white; display: flex; align-items: center; gap: 8px;">
              <span>📋</span> Simuler mes aides
            </h3>
            <p style="font-size: 13.5px; line-height: 1.5; color: var(--primary-light); margin-bottom: 20px;">
              Calculez le montant de la prime ADVENIR et du crédit d'impôt de 500 € pour votre projet.
            </p>
            <a href="/devis/" class="sidebar-cta-gold" style="display: block; text-align: center; background-color: var(--accent); color: white; padding: 12px 20px; border-radius: 9999px; font-weight: 800; text-decoration: none; font-size: 13px; text-transform: uppercase; transition: background-color 0.2s;">
              Obtenir un Devis →
            </a>
          </div>

          <!-- Recommended Articles Widget -->
          <div class="sidebar-widget" style="background: var(--card-bg); padding: 30px; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 700; color: var(--primary); margin-bottom: 20px; padding-bottom: 10px; border-bottom: 2px solid var(--primary-light);">
              Articles Similaires
            </h3>
            <div style="display: flex; flex-direction: column; gap: 20px;">
              {recommendations.map((rec) => (
                <div class="rec-item" style="display: flex; gap: 12px; align-items: start;">
                  <a href={`/guides/${rec.id}/`} style="display: block; width: 70px; height: 50px; border-radius: var(--radius-sm); overflow: hidden; background-color: var(--primary-light); flex-shrink: 0;">
                    <img src={rec.data.image} alt={rec.data.title} style="width: 100%; height: 100%; object-fit: cover;" />
                  </a>
                  <div style="display: flex; flex-direction: column; gap: 4px;">
                    <h4 style="margin: 0; font-size: 13px; line-height: 1.4; font-weight: 700; font-family: var(--font-heading);">
                      <a href={`/guides/${rec.id}/`} style="color: var(--text); text-decoration: none; transition: color 0.2s;">
                        {rec.data.title}
                      </a>
                    </h4>
                    <span style="font-size: 11px; color: var(--text-muted); font-family: var(--font-body);">
                      ⏱️ {rec.data.readTime}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- Security Widget -->
          <div class="sidebar-widget" style="background: var(--card-bg); padding: 30px; border-radius: var(--radius-md); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); font-size: 13px; line-height: 1.5; color: var(--text);">
            <h3 style="font-family: var(--font-heading); font-size: 15px; font-weight: 700; color: var(--primary); margin-bottom: 10px; display: flex; align-items: center; gap: 5px;">
              🛡️ Mention RGE &amp; IRVE
            </h3>
            <p style="margin-bottom: 0;">
              L'installation d'une borne de recharge par un non-professionnel dans les Bouches-du-Rhône annule la garantie de votre véhicule et décharge les assurances de toute responsabilité en cas de sinistre. Exigez toujours la qualification IRVE de votre artisan.
            </p>
          </div>

        </aside>

      </div>
    </div>
  </article>
</Layout>

<style>
  @media (max-width: 992px) {
    .two-column-layout {
      grid-template-columns: 1fr !important;
      gap: 30px !important;
    }
  }
  
  /* Styling markdown content inside .rich-text */
  .rich-text :global(h2) {
    font-family: var(--font-heading);
    font-size: 24px;
    font-weight: 700;
    color: var(--primary);
    margin-top: 35px;
    margin-bottom: 15px;
    border-bottom: 1.5px solid var(--border-color);
    padding-bottom: 8px;
  }
  .rich-text :global(h3) {
    font-family: var(--font-heading);
    font-size: 19px;
    font-weight: 700;
    color: var(--primary);
    margin-top: 25px;
    margin-bottom: 10px;
  }
  .rich-text :global(p) {
    font-size: 15.5px;
    line-height: 1.65;
    color: var(--text);
    margin-bottom: 20px;
  }
  .rich-text :global(ul), .rich-text :global(ol) {
    margin-bottom: 25px;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .rich-text :global(li) {
    font-size: 15px;
    line-height: 1.6;
    color: var(--text);
  }
  .rich-text :global(a) {
    color: var(--secondary);
    text-decoration: underline;
    font-weight: 600;
  }
  .rich-text :global(a:hover) {
    color: var(--primary);
  }
  .rich-text :global(hr) {
    border: 0;
    height: 1px;
    background: var(--border-color);
    margin: 35px 0;
  }
  .rich-text :global(blockquote) {
    border-left: 4px solid var(--accent);
    background: var(--primary-light);
    padding: 15px 25px;
    margin: 25px 0;
    border-radius: var(--radius-sm);
    color: var(--primary);
    font-style: italic;
  }
  .rich-text :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 25px 0;
    font-size: 14px;
  }
  .rich-text :global(th), .rich-text :global(td) {
    border: 1px solid var(--border-color);
    padding: 12px 15px;
    text-align: left;
  }
  .rich-text :global(th) {
    background-color: var(--primary-light);
    color: var(--primary);
    font-weight: 700;
  }
  .rich-text :global(tr:nth-child(even)) {
    background-color: #fafaf9;
  }
  
  .rec-item:hover h4 a {
    color: var(--secondary) !important;
  }
  .sidebar-cta-gold:hover {
    background-color: var(--accent-hover) !important;
    transform: translateY(-1px);
  }

  /* Prevent markdown tables from breaking mobile layout */
  .rich-text :global(table) {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    max-width: 100%;
  }
  
  .guide-main-area {
    min-width: 0;
  }
  .guide-sidebar {
    min-width: 0;
  }
  
  @media (max-width: 768px) {
    .guide-body-card {
      padding: 25px 18px !important;
    }
    .guide-header-details {
      padding: 25px 18px !important;
    }
    .rich-text :global(th), .rich-text :global(td) {
      padding: 8px 10px;
      font-size: 13px;
    }
  }
</style>
